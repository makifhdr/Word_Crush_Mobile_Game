<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:viewModels="clr-namespace:MauiApp5.ViewModels"
             xmlns:models="clr-namespace:MauiApp5.Models"
             x:Class="MauiApp5.Views.GamePage"
             Title="Oyun Ekranı"
             x:Name="GamePageRoot">
    <VerticalStackLayout
        x:Name="MainLayout"
        Padding="15,10,15,30"
        Spacing="10"
        VerticalOptions="Center"
        HorizontalOptions="Center" x:DataType="viewModels:GameViewModel">
        
        <Label
            x:Name="YazilanKelimeLbl"
            HorizontalOptions="Center"
            FontSize="30"
            FontAttributes="Bold"/>
        
        <Label
            x:Name="KalanHamle"
            HorizontalOptions="Center"
            Text="Kalan Hamle"
            FontSize="20"/>
        
        <Label
            x:Name="KalanHamleLbl"
            HorizontalOptions="Center"
            FontSize="20"
            Text="{Binding MovesLeft}"/>
        <skia:SKCanvasView 
            x:Name="GameCanvas"
            HeightRequest="400"
            WidthRequest="400"
            EnableTouchEvents="True"
            Touch="OnCanvasTouch"
            PaintSurface="OnCanvasPaintSurface" />
        
        <HorizontalStackLayout
            Padding="150,10,0,10">
            <Label
                x:Name="PuanLbl"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                FontSize="20"
                FontAttributes="Bold"
                Text="Skor: 0"/>
            <Label
                x:Name="EklenenPuanLbl"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                FontSize="20"
                FontAttributes="Bold"
                Padding = "10,0,0,0"/>
        </HorizontalStackLayout>
        
        <Label
            x:Name="KelimeUyariLbl"
            HorizontalOptions="Center"
            FontSize="15"/>
        
        <CollectionView
            ItemsSource="{Binding Jokers}"
            SelectionMode="None"
            HeightRequest="100">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Joker">
                    <Border 
                        Padding="10" 
                        Margin="5"
                        StrokeThickness="0"
                        BackgroundColor="Transparent">
                        
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="Orange" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </DataTrigger>
                        </Border.Triggers>
                
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:GameViewModel}}, Path=SelectJokerCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <VerticalStackLayout>
                            <Image Source="{Binding ImagePath}" HeightRequest="50" Aspect="AspectFit" />
                            <Label Text="{Binding NumberOf}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>